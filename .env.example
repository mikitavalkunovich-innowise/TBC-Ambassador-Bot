# ============================================================
# TBC Ambassador Bot — Environment Variables
# Copy this file to .env for local development.
# In Railway, set these variables in the dashboard.
# ============================================================

# --- Admin Panel Credentials (required) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Security (required) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# --- Google AI (required) ---
GOOGLE_AI_API_KEY=your-google-ai-studio-api-key

# --- Database (auto-set by Railway PostgreSQL addon) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tbcbot

# --- Telegram Bot (optional at startup; can also be set via admin panel) ---
# If set, this token seeds the DB on first run. Bot token can later be changed via admin panel.
BOT_TOKEN=

# --- Railway Public URL (required for webhook registration) ---
# Set to your Railway service public URL, e.g. https://tbc-ambassador-bot.up.railway.app
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# --- File Storage ---
# Path to the persistent volume mounted in Railway.
# In Railway: mount a volume to /data
UPLOADS_DIR=/data/uploads

# --- App Settings ---
PORT=8000
DEBUG=false
